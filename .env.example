# Database
DATABASE_URL=mysql+pymysql://writoauth:password@mysql:3306/writoauth_db
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=writoauth_db
MYSQL_USER=writoauth
MYSQL_PASSWORD=password

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256

# ChromaDB
CHROMA_DB_PATH=/app/data/chromadb

# AI Models
# HF_MODEL: The Qwen LLM served via Ollama
HF_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# EMBEDDING_MODEL: Sentence transformer for vectorizing text
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# RAG Settings
TOP_K=3
MAX_CONTEXT=4096

# Frontend
# When running in Docker: browser -> backend uses localhost:8000
# When container -> container: use http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
